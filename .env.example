###############################################################################
# Crewtopus – environment template
#
# Copy to `.env` in the directory where you start the backend (often `src/` or
# `src/backend/`), or export variables in your shell. Never commit real secrets.
#
# Note: many variables still use the AGENTHUB_* prefix for compatibility.
###############################################################################

# --- Core server ---
PORT=3000
NODE_ENV=development

# SQLite database path (default: src/backend/data/agenthub.db)
# AGENTHUB_DB_PATH=

# Working directory for agent artifacts, streams, and work-item output
# AGENTHUB_WORK_DIR=

# Optional Redis for job queue (falls back when unset)
# AGENTHUB_REDIS_URL=redis://127.0.0.1:6379
# REDIS_URL=redis://127.0.0.1:6379

# --- Privacy / secrets policy ---
# AGENTHUB_SECRET_POLICY=block
# Options may include redact / continue variants depending on version.
# AGENTHUB_FS_ALLOWLIST=

# --- CLI stream / harness ---
# AGENTHUB_CLI_MAX_OUTPUT_BYTES=10485760
# AGENTHUB_CLI_STREAM_MAX_LOG_BYTES=524288
# AGENTHUB_CLI_STREAM_PERSIST=true
# AGENTHUB_MAX_RING_BUFFERS=50
# AGENTHUB_AUDIT_SNAPSHOTS=true
# AGENTHUB_DISABLE_MOCK_FALLBACK=false
# AGENTHUB_JOB_POLL_MS=500
# AGENTHUB_SHIFT_TICK_MS=60000
# AGENTHUB_STANDUP_INTERVAL_MS=3600000

# --- Grok adapter ---
# GROK_CLI_PATH=grok
# GROK_HOME=
# GROK_CWD=
# GROK_DEFAULT_MODEL=grok-composer-2.5-fast
# GROK_PERMISSION_MODE=acceptEdits
# GROK_ALWAYS_APPROVE=true
# GROK_TIMEOUT_MS=180000
# AGENTHUB_GROK_STREAM=true
# AGENTHUB_GROK_MONTHLY_TOKEN_QUOTA=

# --- Copilot adapter ---
# COPILOT_TIMEOUT_MS=
# COPILOT_HOME=
# COPILOT_DEFAULT_MODEL=auto
# COPILOT_ALLOW_ALL=
# COPILOT_ALLOW_ALL_PATHS=
# COPILOT_YOLO=
# AGENTHUB_COPILOT_MONTHLY_TOKEN_QUOTA=

# --- Claude adapter ---
# CLAUDE_DEFAULT_MODEL=
# AGENTHUB_CLAUDE_MONTHLY_TOKEN_QUOTA=

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=

# --- Frontend (Vite; set in src/frontend/.env if needed) ---
# VITE_BACKEND_PORT=3000
# VITE_WS_URL=
